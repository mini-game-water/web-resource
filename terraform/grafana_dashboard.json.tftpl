            "rawSQL": "SELECT COUNT(*) AS dm_count\nFROM dm_activity\nWHERE event_type = 'dm_sent'\n  AND year = YEAR(CURRENT_DATE)\n  AND month = MONTH(CURRENT_DATE)\n  AND day = DAY(CURRENT_DATE)",
