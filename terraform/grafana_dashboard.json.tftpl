          "datasource": { "type": "grafana-athena-datasource", "uid": "${ds_uid}" },
          "targets": [{
            "connectionArgs": { "region": "${aws_region}", "catalog": "AwsDataCatalog", "database": "${database}" },
            "rawSQL": "SELECT timestamp, room_id, user_id, role, message\nFROM chat_activity\nWHERE year = YEAR(CURRENT_DATE)\n  AND month = MONTH(CURRENT_DATE)\n  AND day = DAY(CURRENT_DATE)\n  AND ('$${filter_user_id}' = '' OR user_id = '$${filter_user_id}')\n  AND ('$${filter_room_id}' = '' OR room_id = '$${filter_room_id}')\nORDER BY timestamp DESC\nLIMIT 100",
            "format": 0
          }]
        },
        {
          "id": 22,
